{
  "rules": {
    "services": {
      "$serviceId": {
        ".read": "true",
        ".write": "true",
        "users": {
          "$userId": {
            ".validate": "newData.hasChildren(['name', 'role', 'x', 'y'])"
          }
        },
        "chat": {
          ".indexOn": ["timestamp"]
        }
      }
    }
  }
}
